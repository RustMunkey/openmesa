{
	"name": "openmesa",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.29.3",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"lint": "turbo lint",
		"format": "turbo format",
		"dev:web": "turbo dev --filter=web",
		"dev:www": "turbo dev --filter=@openmesa/www",
		"dev:console": "turbo dev --filter=@openmesa/console",
		"dev:docs": "turbo dev --filter=@openmesa/docs",
		"dev:desktop": "turbo dev --filter=@openmesa/desktop",
		"dev:ios": "pnpm --filter=@openmesa/desktop ios:dev",
		"dev:android": "pnpm --filter=@openmesa/desktop android:dev",
		"dev:backend": "PYTHONPATH=services/backend services/backend/.venv/bin/python -m backend",
		"build:web": "turbo build --filter=web",
		"build:www": "turbo build --filter=@openmesa/www",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css}": [
			"pnpm exec biome check --write --no-errors-on-unmatched"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.1",
		"turbo": "^2"
	}
}
