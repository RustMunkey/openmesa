{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"format": {
			"cache": false
		}
	}
}
